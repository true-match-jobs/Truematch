# Server Configuration
NODE_ENV=development
PORT=5000

# Frontend CORS Origin (update for production)
FRONTEND_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

# JWT Secrets (generate with: openssl rand -base64 32)
# Minimum 32 characters required
JWT_ACCESS_SECRET=replace_with_strong_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret_min_32_chars_long

# Token Expiration
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Optional: Cookie Domain (for cross-domain cookies in production)
# COOKIE_DOMAIN=.truematch.chat

# Email Service (SMTP)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=replace_with_zoho_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=TrueMatch

# Email Verification
EMAIL_VERIFICATION_TOKEN_EXPIRES_HOURS=720
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# Cloudinary (Image/File Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
